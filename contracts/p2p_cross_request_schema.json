{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P2PCrossRequestSchema",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "requesting_group": {
      "type": "string",
      "minLength": 1
    },
    "target_group": {
      "type": "string",
      "minLength": 1
    },
    "track_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "peer_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "timestamp": {
      "type": "string"
    }
  },
  "required": ["request_id", "requesting_group", "target_group", "track_id", "peer_id", "timestamp"]
}
